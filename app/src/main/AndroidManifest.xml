<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.emotibot.robotvision.game.trexrun">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <uses-feature android:name="android.hardware.camera" />
    <uses-feature android:name="android.hardware.camera.autofocus" />
    <uses-feature android:name="android.hardware.camera.front" />
    <uses-feature android:name="android.hardware.camera.front.autofocus" />

    <application
        android:name="com.emotibot.robotvision.game.trexrun.TrexApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_robot_vision"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_robot_vision"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- android:screenOrientation="portrait" -->


        <activity
            android:name="com.emotibot.robotvision.game.trexrun.activity.StartActivity"
            android:label="TREX Jump"
            android:screenOrientation="landscape"
            android:taskAffinity="com.emotibot.robotvision.standardsample">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.emotibot.robotvision.game.trexrun.activity.GameActivity"
            android:label="TREX Jump"
            android:screenOrientation="landscape"
            android:taskAffinity="com.emotibot.robotvision.standardsample">
            <!--<intent-filter>-->
            <!--<action android:name="android.intent.action.MAIN" />-->
            <!--<category android:name="android.intent.category.LAUNCHER" />-->
            <!--</intent-filter>-->
        </activity>
        <activity
            android:name="com.emotibot.robotvision.game.trexrun.activity.FinishActivity"
            android:label="TREX Jump"
            android:screenOrientation="landscape"
            android:taskAffinity="com.emotibot.robotvision.standardsample"></activity>

        <activity
            android:name="com.emotibot.robotvision.game.trexrun.activity.PlayerCheckActivity"
            android:label="TREX Jump"
            android:screenOrientation="landscape"
            android:taskAffinity="com.emotibot.robotvision.standardsample"></activity>
    </application>

</manifest>