<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>


    <style name="two_line_text_title">
        <item name="android:textSize">@dimen/two_line_text_title_font_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">1</item>
        <item name="android:layout_marginLeft">@dimen/two_line_text_title_margin_left</item>
        <item name="android:layout_marginTop">@dimen/two_line_text_separator_margin_top</item>
        <item name="android:textColor">@color/two_line_text_title_font_color</item>
        <item name="android:gravity">bottom</item>
        <item name="android:layout_gravity">bottom</item>
    </style>

    <style name="image_title_text_title">
        <item name="android:textSize">@dimen/image_title_text_title_font_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">2</item>
        <item name="android:layout_marginTop">@dimen/two_line_text_separator_margin_top</item>
        <item name="android:textColor">@color/two_line_text_title_font_color</item>
        <item name="android:gravity">bottom</item>
        <item name="android:layout_gravity">center_horizontal</item>
    </style>

    <style name="spinner_text0">
        <item name="android:textSize">@dimen/image_title_text_title_font_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">2</item>
        <item name="android:layout_marginTop">@dimen/two_line_text_separator_margin_top</item>
        <item name="android:textColor">@color/two_line_text_title_font_color</item>
        <item name="android:gravity">bottom</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:drawablePadding">0dp</item>
    </style>

    <style name="two_line_text_content">
        <item name="android:textSize">@dimen/two_line_text_content_font_size</item>
        <item name="android:maxLines">1</item>
        <item name="android:layout_marginBottom">@dimen/two_line_text_title_margin_bottom</item>
        <item name="android:gravity">top</item>
        <item name="android:layout_gravity">top|center_horizontal</item>
    </style>

    <style name="attribute_text_title">
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textSize">@dimen/attribute_title_text_font_size</item>
        <item name="android:maxLines">1</item>
        <item name="android:gravity">right</item>
        <item name="android:layout_marginRight">3dp</item>
    </style>

    <style name="attribute_text_value">
        <item name="android:textColor">@color/attribute_value</item>
        <item name="android:textSize">@dimen/attribute_value_text_font_size</item>
        <item name="android:maxLines">1</item>
        <item name="android:gravity">left</item>
    </style>

</resources>
